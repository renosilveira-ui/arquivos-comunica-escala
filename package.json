{
  "name": "escalas-hospitalares",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port ${EXPO_PORT:-8081}",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:web": "expo export --platform web --output-dir web-build",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "check:server": "tsc --noEmit -p server/tsconfig.json",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:server",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "cross-env NODE_ENV=test vitest run tests/shift-workflow.test.ts",
    "e2e:workflow": "tsx scripts/run-e2e-workflow.ts",
    "gate": "pnpm test:e2e && pnpm e2e:workflow",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "seed:staging": "tsx scripts/seed-staging.ts",
    "import:professionals": "tsx scripts/bulk-import-professionals.ts",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "qr": "node scripts/generate_qr.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.2.2",
    "@tanstack/react-query": "^5.100.9",
    "@trpc/client": "11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "11.17.0",
    "@types/fontfaceobserver": "^2.1.3",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "expo": "~54.0.29",
    "expo-audio": "~1.1.0",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.12",
    "expo-device": "^8.0.10",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.10",
    "expo-notifications": "~55.0.22",
    "expo-router": "~6.0.19",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.15",
    "expo-web-browser": "~15.0.10",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.1",
    "fontfaceobserver": "^2.3.0",
    "helmet": "^8.1.0",
    "jose": "6.2.3",
    "lucide-react-native": "^0.563.0",
    "mysql2": "^3.22.3",
    "nativewind": "^4.2.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "superjson": "^1.13.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.14",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.0"
}
